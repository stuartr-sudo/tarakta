# Exchange (Binance)
BINANCE_API_KEY=your_api_key
BINANCE_API_SECRET=your_api_secret

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_service_role_key

# Dashboard Auth
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD_HASH=$2b$12$...  # generate with: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
SESSION_SECRET=change-me-to-a-random-32-char-string

# Trading Config
TRADING_MODE=paper
INITIAL_BALANCE=100.0
ENTRY_THRESHOLD=65
MAX_RISK_PCT=0.02
MAX_CONCURRENT=20
MAX_DAILY_DRAWDOWN=0.10
CIRCUIT_BREAKER_PCT=0.15

# Scanning
SCAN_INTERVAL_MINUTES=15
MIN_VOLUME_USD=500000
QUOTE_CURRENCIES=["USD","USDT"]

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
